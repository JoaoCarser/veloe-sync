# Veloe / Alelo
VELOE_API_BASE_URL=https://api.alelo.com.br/alelo/prd/auto/partner/api
VELOE_CLIENT_ID=
VELOE_CLIENT_SECRET=
VELOE_CONTRACT=
VELOE_AUTHORIZATION_PREFIX=Bearer
VELOE_TOKEN_TTL_MINUTES=120

# Monday
MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_BOARD_ID=18417736509
MONDAY_BOARD_NAME=Veloe / Alelo - Fuel Supply
MONDAY_PAGE_SIZE=500

# n8n
N8N_SUMMARY_WEBHOOK_URL=

# Retry / timeout
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE=1.0
HTTP_BACKOFF_FACTOR=2.0
HTTP_BACKOFF_CAP=30.0
HTTP_JITTER_MIN=0.0
HTTP_JITTER_MAX=0.5
HTTP_REQUEST_TIMEOUT=60
HTTP_REQUEST_PAUSE_SECONDS=0.2

# Veloe pagination
VELOE_VEHICLES_PAGE_SIZE=500
VELOE_SUPPLY_BATCH_SIZE=100
VELOE_SUPPLY_BATCH_SIZE_ON_ERROR=50
VELOE_SUPPLY_WINDOW_DAYS=7

# Pipeline
PIPELINE_LOG_PREFIX=[VELOE]
PIPELINE_SHOW_PROGRESS=true

# Dry-runs: false = executa de verdade | true = simula sem apagar/criar
PIPELINE_CREATE_DRY_RUN=false
PIPELINE_DELETE_DUPLICATE_DRY_RUN=false
PIPELINE_DELETE_ORPHAN_DRY_RUN=false
